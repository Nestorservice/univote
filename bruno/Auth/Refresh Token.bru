meta {
  name: Refresh Token
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/auth/refresh
  body: json
  auth: none
}

body:json {
  {
    "refresh_token": "{{refreshToken}}"
  }
}

script:post-response {
  if (res.status === 200) {
    const body = res.getBody();
    bru.setVar("token", body.data.token);
  }
}

docs {
  # Refresh Token
  Génère un nouveau token JWT à partir du refresh token.
}
