meta {
  name: Get Event Feed
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/v1/events/{{eventId}}/feed?sort=recent&limit=10&cursor=0
  body: none
  auth: none
}

docs {
  # Flux Vidéo (TikTok-like)
  Récupère les vidéos paginées pour un événement.
  - `sort`: `recent` (défaut) ou `popular`
  - `limit`: Nombre de vidéos (max 20)
  - `cursor`: Décalage ou score pour la pagination infinie
}
